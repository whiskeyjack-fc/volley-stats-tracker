# Copy this file to .env and fill in your values.
# .env is excluded from git (see .gitignore).

# PythonAnywhere API token — generate at:
# https://www.pythonanywhere.com/account/#api_token
PA_API_TOKEN=your_api_token_here

# Your PythonAnywhere username
PA_USERNAME=your_username_here

# Your PythonAnywhere web app domain (e.g. your_username.pythonanywhere.com)
PA_DOMAIN=your_username.pythonanywhere.com
